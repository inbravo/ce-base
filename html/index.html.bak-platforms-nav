<script>
// ── state ────────────────────────────────────────────────────────────
let sidebarOpen = false;
let currentSection = 'platforms';

// ── sidebar toggle ────────────────────────────────────────────────────
function toggleSidebar() {
  sidebarOpen ? closeSidebar() : openSidebar();
}
function openSidebar() {
  document.getElementById('sidebar').classList.add('open');
  document.getElementById('overlay').classList.add('visible');
  sidebarOpen = true;
}
window.addEventListener('load', loadPlatformPrefs);

function closeSidebar() {
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('overlay').classList.remove('visible');
  sidebarOpen = false;
}

// ── top nav section switch ────────────────────────────────────────────
// ── settings ──────────────────────────────────────────────────────────
const PLATFORMS = ['aws', 'databricks', 'snowflake', 'azure'];

function toggleSettings() {
  const panel = document.getElementById('settings-panel');
  const overlay = document.getElementById('settings-overlay');
  const isOpen = panel.classList.contains('open');
  if (isOpen) { closeSettings(); } else { panel.classList.add('open'); overlay.classList.add('open'); }
}
function closeSettings() {
  document.getElementById('settings-panel').classList.remove('open');
  document.getElementById('settings-overlay').classList.remove('open');
}
function applyPlatformVisibility() {
  const prefs = {};
  PLATFORMS.forEach(p => {
    const checked = document.getElementById('tog-' + p).checked;
    prefs[p] = checked;
    document.querySelectorAll(`.sidebar-group[data-platform="${p}"]`)
      .forEach(el => el.style.display = checked ? '' : 'none');
  });
  localStorage.setItem('ce-platform-prefs', JSON.stringify(prefs));
}
function resetPlatforms() {
  PLATFORMS.forEach(p => { document.getElementById('tog-' + p).checked = true; });
  applyPlatformVisibility();
}
function loadPlatformPrefs() {
  try {
    const saved = JSON.parse(localStorage.getItem('ce-platform-prefs') || '{}');
    PLATFORMS.forEach(p => {
      if (p in saved) document.getElementById('tog-' + p).checked = saved[p];
    });
    applyPlatformVisibility();
  } catch(e) {}
}

function goHome() {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-home').classList.add('active');
  document.querySelectorAll('.sidebar-item').forEach(i => i.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('breadcrumb').innerHTML = '<span class="crumb-active">Home</span>';
  closeSidebar();
}

function switchSection(section, btn) {
  currentSection = section;
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  ['platforms','concepts','usecases'].forEach(s => {
    const el = document.getElementById('sb-' + s);
    if (el) el.style.display = s === section ? '' : 'none';
  });
  openSidebar();
}

// ── sidebar group expand / collapse ───────────────────────────────────
function ceToggle(idx) {
  const exp = document.getElementById('ce-exp-' + idx);
  const kl  = document.querySelector('.kl-cell[data-idx="' + idx + '"]');
  const wasOpen = exp.classList.contains('open');
  // close all
  document.querySelectorAll('.ce-expand').forEach(e => e.classList.remove('open'));
  document.querySelectorAll('.kl-cell').forEach(k => k.classList.remove('open'));
  // open clicked if it was closed
  if (!wasOpen) { exp.classList.add('open'); kl.classList.add('open'); }
}

function toggleGroup(btn) {
  btn.classList.toggle('expanded');
  const children = btn.nextElementSibling;
  children.classList.toggle('open');
}

function toggleSubGroup(btn) {
  btn.classList.toggle('expanded');
  btn.nextElementSibling.classList.toggle('open');
}

// ── page load ─────────────────────────────────────────────────────────
function loadPage(pageId, crumbs, itemEl) {
  // hide all pages
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  // show target
  const target = document.getElementById('page-' + pageId);
  if (target) target.classList.add('active');

  // update sidebar active state
  document.querySelectorAll('.sidebar-item').forEach(i => i.classList.remove('active'));
  if (itemEl) itemEl.classList.add('active');

  // update breadcrumb
  const bc = document.getElementById('breadcrumb');
  bc.innerHTML = crumbs.map((c, i) =>
    i < crumbs.length - 1
      ? `<span>${c}</span><span class="crumb-sep">›</span>`
      : `<span class="crumb-active">${c}</span>`
  ).join('');

  closeSidebar();
}
</script>

